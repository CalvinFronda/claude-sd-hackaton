  </div>
</div>

<!-- MAIN -->
<main>
  <div>
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;">
      <div class="section-label" style="margin-bottom:0;flex:1;">Environmental Theme Breakdown</div>
      <div class="view-toggle" style="margin-left:20px;">
        <button class="vt-btn active" onclick="switchTab('bars',this)">Bar View</button>
        <button class="vt-btn" onclick="switchTab('trend',this)">Trend</button>
      </div>
    </div>

    <div id="tab-bars" class="tab-panel active">
      <div class="gap-table" id="gapTable"></div>
    </div>

    <div id="tab-trend" class="tab-panel">
      <div id="trendContainer"></div>
    </div>
  </div>

  <div class="sidebar">
    <div class="sidebar-card">
      <div class="section-label">Priority Matrix</div>
      <div style="display:flex;justify-content:space-between;margin-bottom:6px;">
        <span class="axis-label">← Budget Share →</span>
        <span class="axis-label">Comment Share ↑</span>
      </div>
      <div class="matrix-wrap">
        <div class="matrix-inner" id="matrixInner">
          <div class="matrix-cross" style="left:50%;top:0;bottom:0;width:1px;"></div>
          <div class="matrix-cross" style="top:50%;left:0;right:0;height:1px;"></div>
          <div class="matrix-quad-label" style="top:8px;left:8px;">High demand<br>Underfunded ⚠️</div>
          <div class="matrix-quad-label" style="top:8px;right:8px;text-align:right;">High demand<br>Well funded ✓</div>
          <div class="matrix-quad-label" style="bottom:8px;left:8px;">Low demand<br>Underfunded</div>
          <div class="matrix-quad-label" style="bottom:8px;right:8px;text-align:right;">Low demand<br>Over-resourced</div>
        </div>
      </div>
    </div>

    <div class="sidebar-card">
      <div class="section-label">Recommended Actions</div>
      <div id="recList"></div>
    </div>
  </div>
</main>

<footer>City of San Diego · Environmental Services Dept. · Prototype Analysis Tool · FY2025–26 Adopted Budget + Council Minutes AI Analysis · Not for public distribution</footer>

<script>
const themes = [
  { id:'climate', name:'Climate Action & Coastal Resilience', sub:'Sea level rise, GHG reduction, Climate Action Plan', icon:'🌊', commentPct:17.3, budgetPct:4.1, councilPct:6.2, status:'critical', gapScore:-13.2, trend:[{q:"Q1'25",c:12,b:3.8},{q:"Q2'25",c:15,b:4.0},{q:"Q3'25",c:18,b:4.1},{q:"Q4'25",c:21,b:4.0},{q:"Q1'26",c:17,b:4.1}] },
  { id:'air',     name:'Air Quality & Environmental Justice', sub:'Logan Heights, I-5 corridor, port emissions',    icon:'💨', commentPct:8.6,  budgetPct:2.9, councilPct:3.8, status:'critical', gapScore:-5.7,  trend:[{q:"Q1'25",c:6,b:2.8},{q:"Q2'25",c:7,b:2.9},{q:"Q3'25",c:9,b:2.9},{q:"Q4'25",c:10,b:2.9},{q:"Q1'26",c:8,b:2.9}] },
  { id:'water',   name:'Water Supply & Drought Resilience',   sub:'Pure Water program, conservation, rate equity',  icon:'💧', commentPct:4.2,  budgetPct:18.4,councilPct:11.0,status:'overfunded',gapScore:14.2,  trend:[{q:"Q1'25",c:4,b:18.0},{q:"Q2'25",c:5,b:18.2},{q:"Q3'25",c:4,b:18.4},{q:"Q4'25",c:3,b:18.4},{q:"Q1'26",c:4,b:18.4}] },
  { id:'waste',   name:'Zero Waste & Recycling',              sub:'Diversion targets, organics composting, plastics',icon:'♻️', commentPct:3.8,  budgetPct:6.1, councilPct:5.4, status:'balanced', gapScore:2.3,   trend:[{q:"Q1'25",c:3,b:5.9},{q:"Q2'25",c:4,b:6.0},{q:"Q3'25",c:4,b:6.1},{q:"Q4'25",c:4,b:6.1},{q:"Q1'26",c:3,b:6.1}] },
  { id:'urban',   name:'Urban Greening & Tree Canopy',        sub:'Street trees, heat islands, green infrastructure',icon:'🌳', commentPct:5.1,  budgetPct:2.2, councilPct:2.9, status:'underfunded',gapScore:-2.9, trend:[{q:"Q1'25",c:3,b:2.0},{q:"Q2'25",c:4,b:2.1},{q:"Q3'25",c:5,b:2.2},{q:"Q4'25",c:6,b:2.2},{q:"Q1'26",c:5,b:2.2}] },
  { id:'hazmat',  name:'Hazardous Waste & Cleanup',           sub:'Superfund sites, industrial discharge, brownfields',icon:'⚗️',commentPct:2.4,  budgetPct:4.8, councilPct:3.1, status:'overfunded',gapScore:2.4,  trend:[{q:"Q1'25",c:2,b:4.8},{q:"Q2'25",c:2,b:4.8},{q:"Q3'25",c:3,b:4.8},{q:"Q4'25",c:2,b:4.8},{q:"Q1'26",c:2,b:4.8}] }
];

const COLORS = ['#F25C3B','#E84393','#1A90D9','#2EC4A0','#8B5CF6','#F5A623'];
const MAX = 20;

function renderGapTable() {
  const el = document.getElementById('gapTable');
  el.innerHTML = '';
  themes.forEach(t => {
    const neg = t.gapScore < 0;
    const abs = Math.abs(t.gapScore);
    const dc = neg ? 'var(--coral)' : 'var(--sky)';
    const div = document.createElement('div');
    div.className = `gap-row ${t.status}`;
    div.innerHTML = `
      <div class="row-top">
        <div class="row-icon">${t.icon}</div>
        <div><div class="row-title">${t.name}</div><div class="row-sub">${t.sub}</div></div>
      </div>
      <div class="dual-bars">
        <div class="bar-row"><div class="bar-label">Public Comments</div><div class="bar-track"><div class="bar-fill demand" style="width:${(t.commentPct/MAX)*100}%"></div></div><div class="bar-pct" style="color:var(--coral)">${t.commentPct}%</div></div>
        <div class="bar-row"><div class="bar-label">Budget Alloc.</div><div class="bar-track"><div class="bar-fill budget" style="width:${(t.budgetPct/MAX)*100}%"></div></div><div class="bar-pct" style="color:var(--sky)">${t.budgetPct}%</div></div>
        <div class="bar-row"><div class="bar-label">Council Time</div><div class="bar-track"><div class="bar-fill council" style="width:${(t.councilPct/MAX)*100}%"></div></div><div class="bar-pct" style="color:var(--lavender)">${t.councilPct}%</div></div>
      </div>
      <div class="gap-delta-row">
        <div style="display:flex;align-items:center;">
          <span style="color:${dc};font-size:1rem;margin-right:6px;">${neg?'▼':'▲'}</span>
          <span class="delta-num" style="color:${dc}">${abs.toFixed(1)} pts</span>
          <span class="delta-label">${neg?'more public demand than budget — underprioritized':'budget share exceeds public demand share'}</span>
        </div>
        <div style="text-align:right;">
          <div class="score-num" style="color:${dc}">${neg?'−':'+'}${abs.toFixed(1)}</div>
          <div class="score-label">Gap Score</div>
        </div>
      </div>`;
    el.appendChild(div);
  });
}

function renderTrend() {
  const el = document.getElementById('trendContainer');
  const W=680,H=260,PL=40,PT=20,PB=36,PR=20;
  const iW=W-PL-PR, iH=H-PT-PB, maxV=25;
  const xs = iW/(themes[0].trend.length-1);
  const ys = v => iH-(v/maxV)*iH;
  let paths='',dots='';
  themes.forEach((t,i)=>{
    const col=COLORS[i];
    const pc=t.trend.map((d,j)=>`${j*xs},${ys(d.c)}`).join(' ');
    const pb=t.trend.map((d,j)=>`${j*xs},${ys(d.b)}`).join(' ');
    paths+=`<polyline points="${pc}" fill="none" stroke="${col}" stroke-width="2.5" opacity="0.9"/>`;
    paths+=`<polyline points="${pb}" fill="none" stroke="${col}" stroke-width="1.5" stroke-dasharray="4 3" opacity="0.4"/>`;
    t.trend.forEach((d,j)=>{dots+=`<circle cx="${j*xs}" cy="${ys(d.c)}" r="4" fill="${col}" stroke="#0d1b2a" stroke-width="1.5"/>`;});
  });
  const xl=themes[0].trend.map((d,i)=>`<text x="${i*xs}" y="${iH+22}" text-anchor="middle" font-family="DM Mono,monospace" font-size="9" fill="rgba(245,239,224,0.35)">${d.q}</text>`).join('');
  const yl=[0,5,10,15,20,25].map(v=>`<text x="-8" y="${ys(v)+4}" text-anchor="end" font-family="DM Mono,monospace" font-size="9" fill="rgba(245,239,224,0.35)">${v}%</text><line x1="0" y1="${ys(v)}" x2="${iW}" y2="${ys(v)}" stroke="rgba(255,255,255,0.05)" stroke-width="1"/>`).join('');
  const leg=themes.map((t,i)=>`<div style="display:flex;align-items:center;gap:6px;font-size:0.67rem;opacity:0.55;"><div style="width:14px;height:3px;background:${COLORS[i]};border-radius:2px;"></div>${t.name.split(' ').slice(0,2).join(' ')}</div>`).join('');
  el.innerHTML=`
    <div style="display:flex;flex-wrap:wrap;gap:10px;margin-bottom:16px;">${leg}
      <div style="display:flex;align-items:center;gap:6px;font-size:0.67rem;opacity:0.35;">
        <svg width="16" height="8"><line x1="0" y1="4" x2="16" y2="4" stroke="rgba(245,239,224,0.4)" stroke-width="1.5" stroke-dasharray="4 2"/></svg>Budget (dashed)
      </div>
    </div>
    <svg viewBox="0 0 ${W} ${H}" style="width:100%;display:block;">
      <g transform="translate(${PL},${PT})">${yl}${paths}${dots}${xl}</g>
    </svg>
    <div style="margin-top:12px;font-size:0.72rem;opacity:0.45;line-height:1.6;">
      Solid = comment share · Dashed = budget share. <span style="color:var(--coral);opacity:1;">Widening gaps signal unmet civic demand.</span>
    </div>`;
}

function buildMatrix() {
  const inner=document.getElementById('matrixInner');
  themes.forEach((t,i)=>{
    const x=Math.min(t.budgetPct/20,1)*80+10;
    const y=(1-Math.min(t.commentPct/20,1))*80+10;
    const s=18+Math.abs(t.gapScore)*1.1;
    const d=document.createElement('div');
    d.className='matrix-dot';
    d.style.cssText=`left:${x}%;top:${y}%;width:${s}px;height:${s}px;background:${COLORS[i]};opacity:0.85;`;
    d.innerHTML=`<span>${t.icon}</span><div class="matrix-dot-label">${t.name.split(' ').slice(0,2).join(' ')}</div>`;
    inner.appendChild(d);
  });
}

function buildRecs() {
  const recs=[
    {t:"<strong>Reallocate 3–5% of discretionary budget</strong> to Climate Action & Coastal Resilience — 17.3% civic demand vs. 4.1% budget share is the largest gap."},
    {t:"<strong>Request a council agenda time audit</strong> for Air Quality & Environmental Justice — 8.6% of comments receive only 3.8% of discussion time."},
    {t:"<strong>Review Hazardous Waste allocation</strong> (4.8% budget, 2.4% demand) for potential reallocation to higher-demand environmental themes."},
    {t:"<strong>Present a quarterly gap scorecard</strong> to the City Manager — Climate gap has widened 42% over 5 quarters and is a defensible budget argument."},
  ];
  document.getElementById('recList').innerHTML=recs.map((r,i)=>`<div class="rec-item"><div class="rec-num">${i+1}</div><div class="rec-text">${r.t}</div></div>`).join('');
}

function switchTab(id,btn) {
  document.querySelectorAll('.tab-panel').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.vt-btn').forEach(b=>b.classList.remove('active'));
  document.getElementById('tab-'+id).classList.add('active');
  btn.classList.add('active');
}

renderGapTable(); renderTrend(); buildMatrix(); buildRecs();
</script>
</body>
</html>
