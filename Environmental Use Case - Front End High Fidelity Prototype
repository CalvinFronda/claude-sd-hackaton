<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SD Environmental Services — Civic Demand vs. Budget Allocation</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,700;1,9..40,300&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root {
  --sand:    #F5EFE0;
  --ocean:   #0B4F82;
  --sky:     #1A90D9;
  --coral:   #F25C3B;
  --sun:     #F5A623;
  --mint:    #2EC4A0;
  --lavender:#8B5CF6;
  --rose:    #E84393;
  --ink:     #0D1B2A;
  --ink2:    #0f2236;
  --white:   #FFFFFF;
  --rule:    rgba(255,255,255,0.06);
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

body {
  font-family: 'DM Sans', sans-serif;
  background: var(--ink);
  color: var(--sand);
  min-height: 100vh;
  overflow-x: hidden;
}

/* HEADER */
header {
  position: relative;
  overflow: hidden;
  background: linear-gradient(135deg, #0B2F55 0%, #0B4F82 50%, #0D6FA8 100%);
  padding: 0;
}

.header-waves {
  position: absolute; bottom: -2px; left: 0; width: 100%; pointer-events: none;
}

.header-inner {
  display: flex; align-items: center; justify-content: space-between;
  padding: 28px 48px 64px;
  position: relative; z-index: 2;
}

.logo-block { display: flex; align-items: center; gap: 16px; }

.seal {
  width: 64px; height: 64px;
  background: var(--sun);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-family: 'Bebas Neue', sans-serif;
  font-size: 10px; letter-spacing: 0.05em;
  color: var(--ink);
  text-align: center; line-height: 1.2;
  box-shadow: 0 0 0 4px rgba(245,166,35,0.3), 0 0 0 8px rgba(245,166,35,0.1);
  flex-shrink: 0;
  animation: sealPulse 3s ease-in-out infinite;
}

@keyframes sealPulse {
  0%,100% { box-shadow: 0 0 0 4px rgba(245,166,35,0.3), 0 0 0 8px rgba(245,166,35,0.1); }
  50%      { box-shadow: 0 0 0 6px rgba(245,166,35,0.4), 0 0 0 14px rgba(245,166,35,0.15); }
}

.title-block h1 {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(1.8rem, 3vw, 2.6rem);
  letter-spacing: 0.06em; line-height: 1; color: var(--white);
}

.title-block p {
  font-size: 0.78rem; font-weight: 400; opacity: 0.65;
  letter-spacing: 0.12em; text-transform: uppercase; margin-top: 4px;
}

.header-meta { text-align: right; }

.meeting-badge {
  display: inline-block;
  background: rgba(255,255,255,0.1);
  border: 1px solid rgba(255,255,255,0.2);
  border-radius: 100px; padding: 6px 16px;
  font-size: 0.72rem; letter-spacing: 0.1em; text-transform: uppercase;
  font-weight: 500; color: var(--sky); margin-bottom: 8px;
}

.meeting-title {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 1.1rem; letter-spacing: 0.05em; color: var(--sun);
}

.meeting-date { font-size: 0.75rem; opacity: 0.5; margin-top: 4px; }

.legend-pills { display: flex; gap: 10px; justify-content: flex-end; margin-top: 10px; }

.legend-pill {
  display: flex; align-items: center; gap: 7px;
  font-size: 0.72rem; font-weight: 500; letter-spacing: 0.04em;
  padding: 5px 12px; border-radius: 100px;
  background: rgba(255,255,255,0.07);
  border: 1px solid rgba(255,255,255,0.1);
  color: rgba(245,239,224,0.7);
}

.legend-swatch { width: 10px; height: 10px; border-radius: 2px; }

/* STATS STRIP */
.stats-strip {
  background: linear-gradient(90deg, #F25C3B, #F5A623, #2EC4A0, #1A90D9, #8B5CF6);
  height: 4px;
}

/* ALERT */
.alert-banner {
  background: rgba(242,92,59,0.12);
  border-bottom: 1px solid rgba(242,92,59,0.2);
  padding: 14px 48px;
  display: flex; align-items: center; gap: 14px;
  font-size: 0.82rem; color: var(--sand);
}

.alert-icon {
  width: 28px; height: 28px; border-radius: 50%;
  background: rgba(242,92,59,0.2);
  display: flex; align-items: center; justify-content: center;
  font-size: 14px; flex-shrink: 0;
}

/* STATS ROW */
.stats-row {
  display: grid; grid-template-columns: repeat(5, 1fr);
  background: var(--ink2);
  border-bottom: 1px solid var(--rule);
}

.stat-card {
  padding: 22px 28px;
  border-right: 1px solid var(--rule);
  position: relative;
  animation: fadeUp 0.5s ease both;
}

.stat-card:last-child { border-right: none; }

.stat-card::before {
  content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px;
}

.stat-card:nth-child(1)::before { background: var(--coral); }
.stat-card:nth-child(2)::before { background: var(--sky); }
.stat-card:nth-child(3)::before { background: var(--sun); }
.stat-card:nth-child(4)::before { background: var(--mint); }
.stat-card:nth-child(5)::before { background: var(--lavender); }

.stat-label {
  font-size: 0.68rem; text-transform: uppercase; letter-spacing: 0.12em;
  opacity: 0.5; font-weight: 500; margin-bottom: 8px;
}

.stat-value {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 2.2rem; line-height: 1; letter-spacing: 0.02em;
}

.stat-card:nth-child(1) .stat-value { color: var(--coral); }
.stat-card:nth-child(2) .stat-value { color: var(--sky); }
.stat-card:nth-child(3) .stat-value { color: var(--sun); }
.stat-card:nth-child(4) .stat-value { color: var(--mint); }
.stat-card:nth-child(5) .stat-value { color: var(--lavender); }

.stat-sub { font-size: 0.72rem; opacity: 0.45; margin-top: 4px; }

/* MAIN */
main {
  padding: 40px 48px;
  display: grid; grid-template-columns: 1fr 340px;
  gap: 32px; max-width: 1600px; margin: 0 auto;
}

/* SECTION LABEL */
.section-label {
  font-size: 0.68rem; text-transform: uppercase; letter-spacing: 0.15em;
  opacity: 0.4; font-weight: 500; margin-bottom: 16px;
  display: flex; align-items: center; gap: 10px;
}

.section-label::after { content: ''; flex: 1; height: 1px; background: var(--rule); }

/* VIEW TOGGLE */
.view-toggle {
  display: flex; border: 1px solid var(--rule); border-radius: 8px; overflow: hidden; width: fit-content;
}

.vt-btn {
  padding: 8px 20px; font-size: 0.72rem; font-weight: 500;
  letter-spacing: 0.06em; text-transform: uppercase; cursor: pointer;
  border: none; background: transparent; color: rgba(245,239,224,0.45);
  font-family: 'DM Sans', sans-serif; transition: all 0.15s;
  border-right: 1px solid var(--rule);
}

.vt-btn:last-child { border-right: none; }
.vt-btn.active { background: var(--ocean); color: var(--sand); }

.tab-panel { display: none; }
.tab-panel.active { display: block; }

/* GAP ROWS */
.gap-table { display: flex; flex-direction: column; gap: 14px; }

.gap-row {
  background: var(--ink2);
  border: 1px solid var(--rule);
  border-radius: 12px; padding: 22px 26px;
  transition: all 0.25s ease; position: relative; overflow: hidden;
  animation: fadeUp 0.5s ease both;
}

.gap-row:hover {
  border-color: rgba(255,255,255,0.13);
  transform: translateY(-2px);
  box-shadow: 0 8px 32px rgba(0,0,0,0.3);
}

.gap-row::after {
  position: absolute; top: 14px; right: 16px;
  font-family: 'DM Mono', monospace;
  font-size: 0.58rem; letter-spacing: 0.12em; text-transform: uppercase;
  padding: 3px 9px; border-radius: 4px; font-weight: 500;
}

.gap-row.critical::after    { content:'CRITICAL GAP';   background:rgba(242,92,59,0.18);  color:var(--coral);   border:1px solid rgba(242,92,59,0.3); }
.gap-row.underfunded::after { content:'UNDERFUNDED';     background:rgba(245,166,35,0.15); color:var(--sun);     border:1px solid rgba(245,166,35,0.25); }
.gap-row.balanced::after    { content:'BALANCED';        background:rgba(46,196,160,0.15); color:var(--mint);    border:1px solid rgba(46,196,160,0.25); }
.gap-row.overfunded::after  { content:'OVER-RESOURCED';  background:rgba(26,144,217,0.15); color:var(--sky);     border:1px solid rgba(26,144,217,0.25); }

.row-top { display:flex; align-items:flex-start; gap:14px; margin-bottom:18px; }

.row-icon {
  width:40px; height:40px; border-radius:10px;
  display:flex; align-items:center; justify-content:center;
  font-size:18px; flex-shrink:0; background:rgba(255,255,255,0.05);
}

.row-title { font-weight:600; font-size:0.98rem; line-height:1.2; }
.row-sub   { font-size:0.72rem; opacity:0.45; margin-top:3px; font-style:italic; }

.dual-bars { display:flex; flex-direction:column; gap:10px; }

.bar-row {
  display:grid; grid-template-columns:110px 1fr 52px;
  gap:12px; align-items:center;
}

.bar-label {
  font-family:'DM Mono',monospace;
  font-size:0.63rem; text-transform:uppercase; letter-spacing:0.1em; opacity:0.45;
}

.bar-track {
  height:8px; background:rgba(255,255,255,0.06); border-radius:100px; overflow:hidden;
}

.bar-fill { height:100%; border-radius:100px; transition:width 1.2s cubic-bezier(.16,1,.3,1); }
.bar-fill.demand  { background:linear-gradient(90deg,var(--coral),#F28C50); }
.bar-fill.budget  { background:linear-gradient(90deg,var(--sky),#50C8F2); }
.bar-fill.council { background:linear-gradient(90deg,var(--lavender),#C084FC); }

.bar-pct { font-family:'DM Mono',monospace; font-size:0.7rem; text-align:right; font-weight:500; }

.gap-delta-row {
  display:flex; align-items:center; justify-content:space-between;
  margin-top:14px; padding-top:14px; border-top:1px solid var(--rule);
}

.delta-num { font-family:'Bebas Neue',sans-serif; font-size:1.5rem; letter-spacing:0.02em; }
.delta-label { font-size:0.7rem; opacity:0.45; line-height:1.4; max-width:220px; margin-left:8px; }
.score-num { font-family:'Bebas Neue',sans-serif; font-size:1.8rem; line-height:1; }
.score-label { font-size:0.62rem; opacity:0.4; text-transform:uppercase; letter-spacing:0.1em; text-align:right; }

/* SIDEBAR */
.sidebar { display:flex; flex-direction:column; gap:22px; }

.sidebar-card {
  background:var(--ink2); border:1px solid var(--rule);
  border-radius:14px; padding:24px;
  animation:fadeUp 0.6s ease both;
}

/* Matrix */
.matrix-wrap {
  position:relative; width:100%; padding-top:100%;
  border-radius:10px; overflow:hidden; border:1px solid var(--rule);
  background:
    radial-gradient(ellipse at top left, rgba(242,92,59,0.08) 0%, transparent 55%),
    radial-gradient(ellipse at bottom right, rgba(26,144,217,0.08) 0%, transparent 55%);
}

.matrix-inner { position:absolute; top:0; left:0; right:0; bottom:0; padding:12px; }

.matrix-cross { position:absolute; background:rgba(255,255,255,0.06); }

.matrix-quad-label {
  position:absolute; font-size:0.55rem; opacity:0.3;
  font-family:'DM Mono',monospace; letter-spacing:0.06em; text-transform:uppercase; line-height:1.4;
}

.matrix-dot {
  position:absolute; border-radius:50%;
  transform:translate(-50%,-50%); cursor:pointer;
  transition:transform 0.2s;
  display:flex; align-items:center; justify-content:center; font-size:11px;
}

.matrix-dot:hover { transform:translate(-50%,-50%) scale(1.3); z-index:10; }

.matrix-dot-label {
  position:absolute; top:calc(100% + 5px); left:50%; transform:translateX(-50%);
  font-size:0.6rem; white-space:nowrap; font-family:'DM Mono',monospace;
  background:var(--ink2); color:var(--sand);
  padding:2px 6px; border-radius:4px; border:1px solid var(--rule);
  pointer-events:none; opacity:0; transition:opacity 0.2s;
}

.matrix-dot:hover .matrix-dot-label { opacity:1; }

.axis-label {
  font-family:'DM Mono',monospace;
  font-size:0.58rem; text-transform:uppercase; letter-spacing:0.1em; opacity:0.35;
}

/* Recs */
.rec-item {
  display:flex; gap:12px; padding:12px 0; border-bottom:1px solid var(--rule);
}

.rec-item:last-child { border-bottom:none; padding-bottom:0; }

.rec-num {
  font-family:'Bebas Neue',sans-serif; font-size:1.3rem;
  color:var(--coral); flex-shrink:0; width:20px; line-height:1.2;
}

.rec-text { font-size:0.78rem; line-height:1.6; opacity:0.75; }
.rec-text strong { color:var(--sand); font-weight:600; opacity:1; }

@keyframes fadeUp {
  from { opacity:0; transform:translateY(16px); }
  to   { opacity:1; transform:translateY(0); }
}

.gap-row:nth-child(1) { animation-delay:0.05s; }
.gap-row:nth-child(2) { animation-delay:0.10s; }
.gap-row:nth-child(3) { animation-delay:0.15s; }
.gap-row:nth-child(4) { animation-delay:0.20s; }
.gap-row:nth-child(5) { animation-delay:0.25s; }
.gap-row:nth-child(6) { animation-delay:0.30s; }

footer {
  text-align:center; padding:24px 48px;
  font-size:0.68rem; opacity:0.25; letter-spacing:0.1em; text-transform:uppercase;
  border-top:1px solid var(--rule);
}

::-webkit-scrollbar { width:6px; }
::-webkit-scrollbar-track { background:transparent; }
::-webkit-scrollbar-thumb { background:rgba(255,255,255,0.1); border-radius:100px; }

@media (max-width:1100px) {
  main { grid-template-columns:1fr; padding:28px 24px; }
  .header-inner { padding:24px 24px 52px; }
  .stats-row { grid-template-columns:repeat(3,1fr); }
  .alert-banner { padding:12px 24px; }
}
</style>
</head>
<body>

<!-- HEADER -->
<header>
  <div class="header-inner">
    <div class="logo-block">
      <div class="seal">CITY OF<br>SAN<br>DIEGO</div>
      <div class="title-block">
        <h1>Civic Demand vs. Budget Allocation</h1>
        <p>Environmental Services Dept. · Gap Analysis Dashboard · FY 2025–26</p>
