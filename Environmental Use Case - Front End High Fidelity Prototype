        <div class="legend-pill"><div class="legend-swatch" style="background:var(--lavender);"></div>Council Time</div>
      </div>
    </div>
  </div>
  <svg class="header-waves" viewBox="0 0 1440 48" preserveAspectRatio="none" style="height:48px;">
    <path d="M0,48 C360,0 1080,48 1440,16 L1440,48 Z" fill="#0d1b2a"/>
  </svg>
</header>

<div class="stats-strip"></div>

<!-- ALERT -->
<div class="alert-banner">
  <div class="alert-icon">⚠️</div>
  <div>
    <strong style="color:var(--coral);">3 environmental themes are critically underfunded</strong> relative to public comment volume.
    Climate &amp; Coastal Resilience shows the largest gap: <strong style="color:var(--coral);">17.3% of comments vs. 4.1% of budget</strong> — a 13.2 point deficit.
  </div>
</div>

<!-- STATS -->
<div class="stats-row">
  <div class="stat-card">
    <div class="stat-label">Env. Comment Share</div>
