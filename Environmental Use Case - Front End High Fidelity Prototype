  </div>
  <div class="stat-card">
    <div class="stat-label">Demand–Budget Gap</div>
    <div class="stat-value">−17.2 pts</div>
    <div class="stat-sub">civic demand unmatched</div>
  </div>
  <div class="stat-card">
    <div class="stat-label">Council Time Gap</div>
